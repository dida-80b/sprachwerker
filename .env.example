CONTAINER_NAME=sprachwerker
PORT=8095
APP_TITLE=Sprachwerker Studio
DIALECT_NAME=Speech Collection
SOURCE_LANGUAGE_CODE=de-DE
APP_REGION_GROUP=germany
SOURCE_TEXT_LABEL=Dialect / Raw transcript
TARGET_TEXT_LABEL=Approved text
DATASET_PLACEHOLDER=new-dataset-bulk
TRANSLATION_ENABLED=1
TTS_TARGET_HOURS=10
ASR_TARGET_HOURS=3
UI_DEFAULT_LANG=de
DEFAULT_TASK_MODE=both
DEFAULT_AUDIO_DOMAIN=clean
DEFAULT_TARGET_ENGINE=custom
DEFAULT_SPEAKER_PROFILE=single_speaker
DEFAULT_DIALECT_LABEL=
DEFAULT_STYLE_LABEL=neutral
DEFAULT_EMOTION_LABEL=neutral
DEFAULT_RECORDING_QUALITY=clean
DEFAULT_TTS_SUITABILITY=approved
HIP_VISIBLE_DEVICES=0

# Host path used for reviewed datasets
OUTPUT_HOST_DIR=./output
REVIEW_SUBDIR=_sprachwerker

# Backend bootstrap
LLAMA_BACKEND=rocm
ASR_BASE_IMAGE=rocm/dev-ubuntu-22.04:6.3.4-complete
LLAMA_BUILDER_BASE_IMAGE=rocm/dev-ubuntu-22.04:6.3.4-complete
LLAMA_REPO=https://github.com/ggml-org/llama.cpp.git
LLAMA_REF=master
LLAMA_FORCE_REBUILD=0
AMDGPU_TARGETS=
CUDA_DOCKER_ARCH=
LLAMA_CMAKE_EXTRA_ARGS=

# Optional translation helper
OLLAMA_ENDPOINT=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen3.5-tel:latest
PIPER_URL=http://127.0.0.1:5150
PIPER_DEFAULT_VOICE=de_DE-thorsten-high

# Voxtral model bootstrap
HF_TOKEN=
VOXTRAL_HF_REPO=bartowski/mistralai_Voxtral-Small-24B-2507-GGUF
VOXTRAL_MODEL_FILENAME=mistralai_Voxtral-Small-24B-2507-Q4_K_M.gguf
VOXTRAL_MMPROJ_FILENAME=mmproj-mistralai_Voxtral-Small-24B-2507-f16.gguf

# Local ASR backend inside the container
VOXTRAL_CLI_PATH=/opt/llama-bin/llama-mtmd-cli
VOXTRAL_TEXT_CLI_PATH=/opt/llama-bin/llama-completion
VOXTRAL_MODEL_PATH=/models/mistralai_Voxtral-Small-24B-2507-Q4_K_M.gguf
VOXTRAL_MMPROJ_PATH=/models/mmproj-mistralai_Voxtral-Small-24B-2507-f16.gguf
VOXTRAL_LD_LIBRARY_PATH=/opt/llama-bin
VOXTRAL_GPU_LAYERS=72
VOXTRAL_CTX=2048
VOXTRAL_BATCH=512
VOXTRAL_UBATCH=128
VOXTRAL_MAX_TOKENS=96
VOXTRAL_TIMEOUT_SECONDS=120
VOXTRAL_PROMPT_MAX_TOKENS=48
VOXTRAL_PROMPT_TIMEOUT_SECONDS=90
